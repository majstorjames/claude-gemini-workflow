#!/usr/bin/env bash
#
# claude-gemini-workflow pre-commit review gate
# ---------------------------------------------
# Runs a reviewer CLI over the staged diff. If the reviewer replies
# "STATUS: REJECTED" (and REVIEW_MODE=block), the commit is aborted and the
# feedback is printed for you (or the Claude agent) to act on.
#
# Bypass in an emergency:  git commit --no-verify
#
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

# --- defaults (overridable by the repo-root config file) ---------------------
REVIEWER_CMD="gemini"
REVIEWER_MODEL=""   # empty -> use the reviewer CLI's own configured default
REVIEW_MODE="block"

CONF="$ROOT/.claude-gemini-workflow.conf"
# shellcheck disable=SC1090
[ -f "$CONF" ] && . "$CONF"

# --- collect the staged diff -------------------------------------------------
SCRATCH="$ROOT/.git/claude-gemini-workflow"
mkdir -p "$SCRATCH"
DIFF_FILE="$SCRATCH/staged.diff"
git diff --cached --diff-filter=ACMR > "$DIFF_FILE"

# Nothing substantive staged -> allow.
[ -s "$DIFF_FILE" ] || exit 0

# --- graceful degradation if the reviewer isn't installed --------------------
if ! command -v "$REVIEWER_CMD" >/dev/null 2>&1; then
  echo "[cgw] reviewer '$REVIEWER_CMD' not found on PATH — skipping review." >&2
  exit 0
fi

# --- build the review prompt -------------------------------------------------
# Assembled into a file (not a shell var) so large diffs never hit argv limits
# and no quoting in GEMINI.md / the diff can break the script.
PROMPT_FILE="$SCRATCH/prompt.txt"
{
  printf '%s\n' "You are the INDEPENDENT pre-commit reviewer for this repository -- a second, fresh pass whose job is to catch what the change's author normalized or overlooked. You see ONLY the staged diff below (no whole-repo context), so do NOT attempt architecture review -- judge only what the diff itself shows, against the project standards."
  printf '%s\n' ""
  printf '%s\n' "Respond with EXACTLY one of these on the FIRST line:"
  printf '%s\n' "  STATUS: APPROVED"
  printf '%s\n' "  STATUS: REJECTED"
  printf '%s\n' "After the STATUS line, ALWAYS list -- as separate bulleted lines each starting with '- ' -- the specific things you verified in this diff (e.g. files, functions, migrations, behaviors); give 2-5 bullets. This proves you engaged, and applies to APPROVED as much as REJECTED. Never approve without listing what you verified."
  printf '%s\n' "If REJECTED, each bullet should name the problem and end with a concise, actionable, file-anchored fix. Reject only for: correctness regressions introduced by this change, security issues in the changed lines, broken contracts (signatures, callers/callees, schemas) visible in the diff, or changed behavior with no corresponding test -- never for style nitpicks."
  printf '%s\n' ""
  printf '%s\n' "=== PROJECT STANDARDS (GEMINI.md) ==="
  if [ -f "$ROOT/GEMINI.md" ]; then cat "$ROOT/GEMINI.md"; else printf '%s\n' "<none provided>"; fi
  printf '%s\n' ""
  printf '%s\n' "=== STAGED DIFF ==="
  cat "$DIFF_FILE"
} > "$PROMPT_FILE"

# Only pass -m when a model is pinned; otherwise let the CLI use its own default.
MODEL_ARGS=()
[ -n "$REVIEWER_MODEL" ] && MODEL_ARGS=(-m "$REVIEWER_MODEL")

if [ -n "$REVIEWER_MODEL" ]; then
  echo "[cgw] Reviewing staged changes with $REVIEWER_CMD ($REVIEWER_MODEL)..." >&2
else
  echo "[cgw] Reviewing staged changes with $REVIEWER_CMD (CLI default model)..." >&2
fi

# Feed the prompt via stdin (robust for large diffs vs. argv length limits).
# If the reviewer invocation itself errors, fail open (allow the commit).
# Guarded array expansion: safe when MODEL_ARGS is empty under `set -u` on bash 3.2 (macOS).
if ! REVIEW_OUTPUT="$("$REVIEWER_CMD" ${MODEL_ARGS[@]+"${MODEL_ARGS[@]}"} < "$PROMPT_FILE" 2>&1)"; then
  echo "[cgw] reviewer invocation failed — allowing commit." >&2
  echo "$REVIEW_OUTPUT" >&2
  exit 0
fi

# --- render the verdict ------------------------------------------------------
# Color only when stderr is an interactive terminal; plain text when the output
# is captured (e.g. by the Claude agent) so no escape codes leak into logs.
if [ -t 2 ]; then
  C_GREEN=$'\033[32m'; C_RED=$'\033[31m'; C_YELLOW=$'\033[33m'
  C_BOLD=$'\033[1m';   C_RESET=$'\033[0m'
else
  C_GREEN=""; C_RED=""; C_YELLOW=""; C_BOLD=""; C_RESET=""
fi
RULE="────────────────────────────────────────────"

emit() { printf '%s\n' "$1" >&2; }

# Everything the reviewer said except the STATUS line, blank lines dropped.
DETAIL="$(printf '%s\n' "$REVIEW_OUTPUT" | grep -viE '^[[:space:]]*STATUS:' | grep -v '^[[:space:]]*$' || true)"

# --- gate --------------------------------------------------------------------
if printf '%s' "$REVIEW_OUTPUT" | grep -qiE 'STATUS:[[:space:]]*REJECTED'; then
  emit ""
  emit "${C_RED}${C_BOLD}${RULE}${C_RESET}"
  emit "${C_RED}${C_BOLD} ✗ REVIEW FAILED — issues found${C_RESET}"
  emit "${C_RED}${C_BOLD}${RULE}${C_RESET}"
  if [ -n "$DETAIL" ]; then
    printf '%s\n' "$DETAIL" | while IFS= read -r line; do
      clean="$(printf '%s' "$line" | sed -E 's/^[[:space:]]*[-*][[:space:]]*//')"
      emit "${C_RED} ✗${C_RESET} ${clean}"
    done
  else
    emit "${C_RED} ✗${C_RESET} (no detail provided)"
  fi
  emit ""
  if [ "$REVIEW_MODE" = "block" ]; then
    emit "${C_RED}[cgw] Commit blocked. Fix the issues above, then re-commit — or bypass with: git commit --no-verify${C_RESET}"
    exit 1
  else
    emit "${C_YELLOW}[cgw] warn mode — commit NOT blocked, but address the issues above.${C_RESET}"
    exit 0
  fi
elif printf '%s' "$REVIEW_OUTPUT" | grep -qiE 'STATUS:[[:space:]]*APPROVED'; then
  emit ""
  emit "${C_GREEN}${C_BOLD}${RULE}${C_RESET}"
  emit "${C_GREEN}${C_BOLD} ✓ REVIEW PASSED — commit allowed${C_RESET}"
  emit "${C_GREEN}${C_BOLD}${RULE}${C_RESET}"
  if [ -n "$DETAIL" ]; then
    printf '%s\n' "$DETAIL" | while IFS= read -r line; do
      clean="$(printf '%s' "$line" | sed -E 's/^[[:space:]]*[-*][[:space:]]*//')"
      emit "${C_GREEN} ✓${C_RESET} ${clean}"
    done
  else
    emit "${C_GREEN} ✓${C_RESET} (no detail provided)"
  fi
  emit ""
  exit 0
else
  # Unrecognized / malformed verdict: fail open but make it visible.
  emit ""
  emit "${C_YELLOW}${C_BOLD} ⚠ [cgw] Review returned no clear STATUS — allowing commit.${C_RESET}"
  emit "$REVIEW_OUTPUT"
  emit ""
  exit 0
fi
